---
import App from '../components/App';
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';
import '../styles/global.css';

// Auto-discover any images dropped into public/blog/<slug>/ — alphabetical.
// Used as the default gallery when frontmatter doesn't specify one.
const autoGallery = (slug: string): string[] => {
  const dir = path.join(process.cwd(), 'public', 'blog', slug);
  try {
    return fs.readdirSync(dir)
      .filter((f) => /\.(jpe?g|png|webp|gif|avif)$/i.test(f))
      .sort()
      .map((f) => `/blog/${slug}/${f}`);
  } catch {
    return [];
  }
};

// Build-time: read all blog posts, render their markdown bodies to HTML,
// pass to the React app as a prop. Sorted newest first.
const entries = await getCollection('blog');
const posts = await Promise.all(
  entries
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
    .map(async (p) => {
      const auto = autoGallery(p.id);
      const gallery = p.data.gallery ?? (auto.length > 0 ? auto : null);
      return {
        slug: p.id,
        title: p.data.title,
        date: p.data.date.toISOString().slice(0, 10),
        summary: p.data.summary ?? null,
        gallery,
        bodyHtml: await marked.parse(p.body ?? ''),
      };
    }),
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Elias Rode — student of mathematics & philosophy at Trinity College Dublin. Personal site, works, writing, and contact." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" href="/favicon.ico?v=2" />

    <!-- Open Graph (Facebook, LinkedIn, iMessage, Slack, …) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Elias Rode" />
    <meta property="og:title" content="Elias Rode" />
    <meta property="og:description" content="A Brief Index of Personal Works & Correspondence — student of mathematics & philosophy, Trinity College Dublin." />
    <meta property="og:url" content="https://eliasro.de" />
    <meta property="og:image" content="https://eliasro.de/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Title page reading 'Elias Rode — A Brief Index of Personal Works & Correspondence', cream paper with sepia ink." />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Elias Rode" />
    <meta name="twitter:description" content="A Brief Index of Personal Works & Correspondence — student of mathematics & philosophy, Trinity College Dublin." />
    <meta name="twitter:image" content="https://eliasro.de/og.png" />

    <!-- Theme colour for browser chrome (matches paper) -->
    <meta name="theme-color" content="#f3ead2" />
    <!-- Computer Modern Serif is self-hosted; see @font-face block at the
         top of global.css. EB Garamond / Cormorant / JetBrains Mono remain
         from Google Fonts as fallbacks. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>Elias Rode</title>
  </head>
  <body>
    <App client:load posts={posts} />
  </body>
</html>
